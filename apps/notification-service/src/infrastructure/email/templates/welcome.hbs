<h2 style="margin: 0 0 16px; color: #1a1a2e; font-size: 22px;">Welcome,
  {{name}}!</h2>
<p style="margin: 0 0 16px; color: #495057; font-size: 15px; line-height: 1.6;">
  Your account has been created successfully. You are now ready to start using
  the AI Interview Platform.
</p>
<p style="margin: 0 0 24px; color: #495057; font-size: 15px; line-height: 1.6;">
  Your role:
  <strong>{{role}}</strong>
</p>
<table
  role="presentation"
  cellpadding="0"
  cellspacing="0"
  style="margin: 0 auto;"
>
  <tr>
    <td style="background-color: #4c6ef5; border-radius: 6px;">
      <a
        href="{{frontendUrl}}"
        style="display: inline-block; padding: 12px 28px; color: #ffffff; text-decoration: none; font-size: 15px; font-weight: 600;"
      >Get Started</a>
    </td>
  </tr>
</table>