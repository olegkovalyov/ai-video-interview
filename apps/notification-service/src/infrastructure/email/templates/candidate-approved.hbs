<h2 style="margin: 0 0 16px; color: #0f172a; font-size: 22px;">
  🎉 Congratulations,
  {{candidateName}}!
</h2>

<p style="margin: 0 0 16px; color: #334155; font-size: 15px; line-height: 1.6;">
  Great news — your interview for
  <strong>{{templateTitle}}</strong>
  at
  <strong>{{companyName}}</strong>
  has been reviewed and you have been
  <strong style="color: #059669;">approved</strong>.
</p>

{{#if note}}
  <div
    style="margin: 20px 0; padding: 16px 20px; background-color: #ecfdf5; border-left: 4px solid #10b981; border-radius: 4px;"
  >
    <p
      style="margin: 0 0 4px; color: #047857; font-size: 13px; font-weight: 600;"
    >
      Message from
      {{companyName}}:
    </p>
    <p
      style="margin: 0; color: #1e293b; font-size: 14px; line-height: 1.6; white-space: pre-wrap;"
    >
      {{note}}
    </p>
  </div>
{{/if}}

<p
  style="margin: 20px 0 24px; color: #334155; font-size: 15px; line-height: 1.6;"
>
  You can view the full details of your interview and AI analysis results in
  your dashboard.
</p>

<table
  role="presentation"
  cellpadding="0"
  cellspacing="0"
  style="margin: 0 auto;"
>
  <tr>
    <td>
      <a
        href="{{frontendUrl}}/candidate/dashboard"
        class="btn"
        style="display: inline-block; padding: 12px 24px; background-color: #6366f1; color: #ffffff !important; text-decoration: none; font-size: 14px; font-weight: 600; border-radius: 6px;"
      >
        View in Dashboard
      </a>
    </td>
  </tr>
</table>