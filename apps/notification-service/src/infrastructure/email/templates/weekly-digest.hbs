<h2 style="margin: 0 0 16px; color: #1a1a2e; font-size: 22px;">Weekly Digest</h2>
<p style="margin: 0 0 16px; color: #495057; font-size: 15px; line-height: 1.6;">
  Here is your weekly summary:
</p>
<table
  role="presentation"
  width="100%"
  cellpadding="0"
  cellspacing="0"
  style="margin: 0 0 24px;"
>
  <tr>
    <td
      style="padding: 12px 16px; background-color: #f8f9fa; border-radius: 6px 6px 0 0; border-bottom: 1px solid #e9ecef;"
    >
      <strong style="color: #1a1a2e;">New Candidates</strong>
      <span
        style="float: right; color: #4c6ef5; font-weight: 600;"
      >{{newCandidates}}</span>
    </td>
  </tr>
  <tr>
    <td
      style="padding: 12px 16px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef;"
    >
      <strong style="color: #1a1a2e;">Pending Reviews</strong>
      <span
        style="float: right; color: #f59f00; font-weight: 600;"
      >{{pendingReviews}}</span>
    </td>
  </tr>
  <tr>
    <td
      style="padding: 12px 16px; background-color: #f8f9fa; border-radius: 0 0 6px 6px;"
    >
      <strong style="color: #1a1a2e;">Completed Interviews</strong>
      <span
        style="float: right; color: #40c057; font-weight: 600;"
      >{{completedInterviews}}</span>
    </td>
  </tr>
</table>
<table
  role="presentation"
  cellpadding="0"
  cellspacing="0"
  style="margin: 0 auto;"
>
  <tr>
    <td style="background-color: #4c6ef5; border-radius: 6px;">
      <a
        href="{{frontendUrl}}/dashboard"
        style="display: inline-block; padding: 12px 28px; color: #ffffff; text-decoration: none; font-size: 15px; font-weight: 600;"
      >Go to Dashboard</a>
    </td>
  </tr>
</table>