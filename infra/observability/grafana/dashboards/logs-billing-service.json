      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 105,
      "title": "Full Log Stream",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 42 },
      "id": 15,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "title": "All Logs",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"billing-service\", level=~\"$level\"} | json | line_format \"{{.timestamp}} [{{.level}}] {{.message}} {{if .action}}action={{.action}}{{end}} {{if .correlationId}}cid={{.correlationId}}{{end}}\"",
          "refId": "A"
        }
      ]
    }
  ]
}
