          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "billing_service_cache_misses_total",
          "legendFormat": "misses — {{layer}} / {{key_type}}",
